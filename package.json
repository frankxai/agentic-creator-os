{
  "name": "@frankx/agentic-creator-os",
  "version": "12.0.0",
  "description": "Agentic Creator OS — the open-source operating system for AI-powered creators. Skills, commands, agents, and hooks for content, video, music, visual, and brand workflows across Claude Code and other AI coding agents.",
  "author": "Frank Riemer <frank@frankx.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankxai/agentic-creator-os"
  },
  "homepage": "https://frankx.ai/acos",
  "bugs": {
    "url": "https://github.com/frankxai/agentic-creator-os/issues"
  },
  "keywords": [
    "claude-code",
    "grok",
    "grok-cli",
    "grok-build",
    "xai",
    "cursor",
    "windsurf",
    "gemini",
    "antigravity",
    "ai-agent",
    "creator-tools",
    "mcp",
    "anthropic",
    "skills",
    "workflows",
    "content-creation",
    "agentic-ai",
    "sip",
    "starlight-intelligence"
  ],
  "bin": {
    "acos": "./bin/acos-sync.sh",
    "acos-sync": "./bin/acos-sync.sh",
    "acos-enhance": "./bin/acos-enhance"
  },
  "files": [
    ".claude/",
    ".claude-plugin/",
    ".mcp.json",
    "bin/",
    "hooks/",
    "mcp-servers/",
    "skills/",
    "templates/",
    "workflows/",
    "tools/observatory/",
    "scripts/build-catalog.mjs",
    "scripts/generate-stats.mjs",
    "install.sh",
    "CLAUDE.md",
    "CREATOR.md",
    "STATS.md",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "mcp-servers/*"
  ],
  "scripts": {
    "observatory": "node tools/observatory/server.mjs",
    "observatory:catalog": "node scripts/build-catalog.mjs",
    "observatory:install-hooks": "node tools/observatory/install-hooks.mjs",
    "observatory:test": "node --test scripts/build-catalog.test.mjs",
    "install:all": "npm install --workspaces",
    "build:all": "npm run build --workspaces",
    "typecheck:all": "npm run typecheck --workspaces --if-present",
    "dev:all": "npm run dev --workspaces",
    "postinstall": "echo '\\n🚀 Agentic Creator OS installed! Run: ./install.sh\\n'",
    "publish": "npm run build:all && npm publish",
    "version:bump": "npm version $npm_config_version && git push && git push --tags",
    "lint": "node scripts/lint.mjs"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  },
  "overrides": {
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
