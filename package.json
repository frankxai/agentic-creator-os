{
  "name": "@frankx/agentic-creator-os",
  "version": "11.0.0",
  "description": "The Operating System for AI-Powered Creators — 90+ skills, 65+ commands, 38 agents, 8 plugins. Works with Claude Code, Cursor, Windsurf, Gemini.",
  "author": "Frank Guzman <frank@frankx.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankxai/agentic-creator-os"
  },
  "homepage": "https://frankx.ai/products/agentic-creator-os",
  "bugs": {
    "url": "https://github.com/frankxai/agentic-creator-os/issues"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "windsurf",
    "gemini",
    "ai-agent",
    "creator-tools",
    "mcp",
    "anthropic",
    "skills",
    "workflows",
    "content-creation",
    "agentic-ai"
  ],
  "bin": {
    "acos": "./bin/acos-sync.sh",
    "acos-sync": "./bin/acos-sync.sh",
    "acos-enhance": "./bin/acos-enhance"
  },
  "files": [
    "bin/",
    "departments/",
    "instances/",
    "mcp-servers/",
    "skills/",
    "templates/",
    "workflows/",
    "docs/",
    "tools/observatory/",
    "scripts/build-catalog.mjs",
    "scripts/build-catalog.test.mjs",
    "install.sh",
    "CLAUDE.md",
    "CREATOR_NEEDS.md",
    "README.md"
  ],
  "workspaces": [
    "mcp-servers/*"
  ],
  "scripts": {
    "observatory": "node tools/observatory/server.mjs",
    "observatory:catalog": "node scripts/build-catalog.mjs",
    "observatory:install-hooks": "node tools/observatory/install-hooks.mjs",
    "observatory:test": "node --test scripts/build-catalog.test.mjs",
    "install:all": "npm install --workspaces",
    "build:all": "npm run build --workspaces",
    "typecheck:all": "npm run typecheck --workspaces --if-present",
    "dev:all": "npm run dev --workspaces",
    "postinstall": "echo '\\n🚀 Agentic Creator OS installed! Run: ./install.sh\\n'",
    "publish": "npm run build:all && npm publish",
    "version:bump": "npm version $npm_config_version && git push && git push --tags",
    "lint": "node scripts/lint.mjs"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  },
  "overrides": {
    "typescript": "5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
