{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Observatory",
  "version": "0.1.0",
  "identifier": "ai.frankx.agent-observatory",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:4317"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Observatory",
        "url": "http://localhost:4317",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "theme": "Dark",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:4317; connect-src 'self' http://localhost:4317; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "tooltip": "Agent Observatory"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Live monitor for the Agentic Creator OS agent fleet.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": {
      "../server.mjs": "observatory/server.mjs",
      "../web": "observatory/web",
      "../public/catalog.json": "observatory/public/catalog.json"
    }
  }
}
