{
  "_description": "ACOS v7.0 Model Routing Rules - Intelligent Haiku/Sonnet/Opus/Fable selection",
  "_version": "2.0.0",
  "_source": "claude-flow Q-Learning Router pattern + model-registry.json",
  "_updated": "2026-06-10",
  "_note": "Updated for Fable 5 (creative/reasoning), Opus 4.6 (adaptive thinking, 1M context)",

  "models": {
    "haiku": {
      "id": "claude-haiku-4-5-20251001",
      "cost_per_1m_input": 0.80,
      "cost_per_1m_output": 4.0,
      "latency": "fastest",
      "capability": "basic",
      "use_for": [
        "Simple file operations",
        "Scaffolding and boilerplate",
        "Status checks",
        "Deployment execution",
        "Formatting and linting",
        "List operations"
      ]
    },
    "sonnet": {
      "id": "claude-sonnet-4-6",
      "cost_per_1m_input": 3.0,
      "cost_per_1m_output": 15.0,
      "latency": "medium",
      "capability": "balanced",
      "use_for": [
        "Feature implementation",
        "Content creation",
        "Code review",
        "Bug fixes",
        "Test generation",
        "API integration"
      ]
    },
    "fable": {
      "id": "claude-fable-5",
      "cost_per_1m_input": 3.5,
      "cost_per_1m_output": 12.0,
      "context_window": 200000,
      "max_output_tokens": 64000,
      "latency": "medium",
      "capability": "creative-reasoning",
      "specialization": ["narrative", "artistic", "emotional", "philosophical"],
      "use_for": [
        "Deep narrative and fiction writing",
        "Music prompt engineering",
        "Creative copywriting",
        "Brand voice and tone",
        "Artistic direction",
        "Emotional resonance tuning",
        "Complex reasoning chains",
        "Philosophical analysis",
        "Character development"
      ]
    },
    "opus": {
      "id": "claude-opus-4-8",
      "cost_per_1m_input": 5.0,
      "cost_per_1m_output": 25.0,
      "context_window": 200000,
      "context_window_beta": 1000000,
      "max_output_tokens": 128000,
      "thinking_mode": "adaptive",
      "effort_levels": ["low", "medium", "high", "max"],
      "latency": "slowest",
      "capability": "maximum",
      "use_for": [
        "Architecture decisions",
        "Strategic planning",
        "Multi-agent coordination",
        "Complex debugging",
        "Security audits",
        "Research synthesis",
        "Enterprise system design",
        "Long-horizon planning"
      ]
    }
  },

  "command_routing": {
    "haiku": [
      "/mcp-status",
      "/inventory-status",
      "/publish",
      "/nextjs-deploy"
    ],
    "sonnet": [
      "/acos",
      "/spec",
      "/ux-design",
      "/automation-dev",
      "/planning-with-files",
      "/classify-content",
      "/infogenius",
      "/generate-images"
    ],
    "fable": [
      "/article-creator",
      "/create-music",
      "/generate-social",
      "/author-team",
      "/factory",
      "/polish-content",
      "/review-content",
      "/hook"
    ],
    "opus": [
      "/starlight-architect",
      "/council",
      "/research",
      "/plan-week",
      "/starlight-intelligence",
      "/products-creation",
      "/harvest"
    ]
  },

  "keyword_routing": {
    "haiku_keywords": [
      "status", "check", "list", "deploy", "format", "lint", "scaffold",
      "simple", "quick", "fast"
    ],
    "sonnet_keywords": [
      "implement", "fix", "build", "test", "feature", "review", "debug",
      "api", "integration", "refactor"
    ],
    "fable_keywords": [
      "write", "create", "story", "narrative", "voice", "tone", "creative",
      "music", "song", "lyric", "melody", "emotional", "artistic", "poetry",
      "character", "hook", "content", "article", "blog", "social"
    ],
    "opus_keywords": [
      "architect", "design", "strategy", "council", "enterprise", "complex",
      "research", "plan", "analyze", "system", "multi-agent", "book",
      "security", "audit", "synthesis"
    ]
  },

  "escalation_rules": {
    "enabled": true,
    "max_retries": 2,
    "escalation_path": ["haiku", "sonnet", "fable", "opus"],
    "creative_escalation_path": ["sonnet", "fable", "opus"],
    "reasoning_escalation_path": ["sonnet", "fable", "opus"],
    "escalation_triggers": [
      "task_failed",
      "quality_below_threshold",
      "complexity_underestimated",
      "creative_depth_needed",
      "reasoning_chain_required"
    ]
  },

  "cost_optimization": {
    "enabled": true,
    "target_savings": 0.5,
    "prefer_cheaper_when_ambiguous": true,
    "track_actual_vs_predicted": true,
    "creative_tasks_prefer_fable": true,
    "reasoning_tasks_prefer_fable": true
  },

  "agent_routing": {
    "haiku_agents": [
      "performance-guardian",
      "seo-specialist"
    ],
    "sonnet_agents": [
      "nextjs-vercel-deployment",
      "ui-ux-design-guidance",
      "mcp-server-advising",
      "nano-banana-image-generation",
      "code-analyzer"
    ],
    "fable_agents": [
      "deep-fiction-writer",
      "music-production",
      "frankx-content-creation",
      "social-content-generator",
      "content-polisher",
      "line-editor-voice-alchemist",
      "character-psychologist",
      "prompt-psyche-cartographer",
      "prompt-psychometrist"
    ],
    "opus_agents": [
      "starlight-orchestrator",
      "luminor-strategic-guidance",
      "master-story-architect",
      "golden-age-visionary",
      "world-architect",
      "research-librarian",
      "strategist"
    ]
  }
}
